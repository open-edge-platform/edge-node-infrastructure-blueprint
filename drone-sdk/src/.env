# ─────────────────────────────────────────────────────────────────────────────
# Proxy configuration
#
# If you are on a home or open network → leave all three values EMPTY.
# If you are on a corporate network    → fill in your proxy address.
#
# Examples:
#   HTTP_PROXY=http://proxy.myproxy.com:8080
#   HTTPS_PROXY=http://proxy.myproxy.com:8080
#   NO_PROXY=localhost,127.0.0.0/8
# ─────────────────────────────────────────────────────────────────────────────
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.0/8

# ─────────────────────────────────────────────────────────────────────────────
# Simulation home position  (Zurich Irchel Park — PX4 default)
# Change to your location if you want realistic GPS coordinates.
# ─────────────────────────────────────────────────────────────────────────────
PX4_HOME_LAT=47.397742
PX4_HOME_LON=8.545594
PX4_HOME_ALT=488.0

# Simulation speed multiplier. 1 = real-time.  2 = 2x faster.
PX4_SIM_SPEED_FACTOR=1

# REST API port for the companion computer bridge
API_PORT=8080
